{
  "name": "abletongpt-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Localhost companion that bridges AbletonGPT to Ableton Live via the Extensions SDK. Protocol abletongpt.extensions.v1.",
  "main": "dist/extension.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "abletongpt-extension-mock": "index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "npm run build:dev && extensions-cli run",
    "start:mock": "node index.js",
    "test": "node --test"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:vendor/ableton-extensions-sdk-1.0.0-beta.0.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:vendor/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^24.1.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "allowScripts": {
    "esbuild@0.28.0": true
  }
}
