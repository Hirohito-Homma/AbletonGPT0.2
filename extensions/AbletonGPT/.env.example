# Path to Ableton Live's Extension Host module (for `npm start` via extensions-cli).
# Each developer sets this for their own machine; .env is gitignored.
EXTENSION_HOST_PATH=/Applications/Ableton Live 12.4 Beta.app

# Shared secret with the AbletonGPT Python bridge (must match ABLETONGPT_EXTENSIONS_TOKEN).
ABLETONGPT_EXTENSIONS_TOKEN=replace-with-a-shared-token
